# === TerraTunnel Analyzer — Environment Configuration ===
# Copy this file to .env and fill in your values.

# Z.ai / Zhipu AI API Key
# - Set a real key to enable LIVE mode (GLM-5.2 analysis)
# - Leave as placeholder for DEMO mode (mock responses)
ZHIPU_API_KEY=your_api_key_here

# API Base URL — choose one:
#   International: https://api.z.ai/api/paas/v4
#   China:         https://open.bigmodel.cn/api/paas/v4
#   Local Ollama:  http://localhost:11434/v1
ZHIPU_API_BASE=https://api.z.ai/api/paas/v4

# Model identifier
GLM_MODEL=glm-5.2

# Mode override (optional — auto-detects from API key if not set)
#   demo  → Always use mock responses
#   live  → Always call GLM-5.2 API
#   (empty) → Auto-detect from ZHIPU_API_KEY
# MODE=
